{
	"name": "@filosign/contracts",
	"version": "0.1.0",
	"description": "Filosign on-chain contracts, ABIs, and public chain manifests",
	"exports": {
		"./abis": {
			"types": "./abis/index.ts",
			"default": "./abis/index.ts"
		},
		"./chains": {
			"types": "./chains/index.ts",
			"default": "./chains/index.ts"
		}
	},
	"scripts": {
		"compile": "bunx --bun hardhat compile",
		"test": "bun compile && bunx --bun hardhat test",
		"export-abi": "bun run scripts/export-abi.ts",
		"check": "biome check abis chains scripts",
		"check-types": "tsc --noEmit -p tsconfig.json"
	},
	"devDependencies": {
		"@nomicfoundation/hardhat-network-helpers": "^1.1.0",
		"@nomicfoundation/hardhat-toolbox-viem": "^4.1.0",
		"@nomicfoundation/hardhat-viem": "^2.1.1",
		"@openzeppelin/contracts": "^5.4.0",
		"@types/bun": "catalog:",
		"@types/chai": "^4.3.20",
		"@types/mocha": "^10.0.10",
		"@types/node": "catalog:",
		"chai": "^4.5.0",
		"hardhat": "^2.26.3",
		"mocha": "11.7.4",
		"typescript": "catalog:",
		"viem": "catalog:"
	},
	"peerDependencies": {
		"viem": "catalog:"
	}
}
